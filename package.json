{
  "name": "design-diffusion",
  "version": "0.1.0",
  "private": true,
  "description": "Design Diffusion — AI x fashion co-creation. Core interaction layer.",
  "type": "module",
  "scripts": {
    "build": "npm run tokens && npm run core && esbuild src/index.ts --bundle --format=iife --global-name=DD --target=es2019 --outfile=dist/dd.js",
    "tokens": "esbuild src/tokens.ts --bundle --format=esm --outfile=node_modules/.dd/tokens.mjs --log-level=error && node scripts/gen-tokens.mjs",
    "core": "esbuild src/grow.ts --bundle --format=esm --outfile=api/_grow-core.mjs --log-level=error",
    "check": "tsc --noEmit",
    "check:core": "esbuild scripts/check-core.ts --bundle --format=esm --platform=node --outfile=node_modules/.dd/check.mjs --log-level=error && node node_modules/.dd/check.mjs",
    "e2e": "npm run build && node scripts/e2e.mjs",
    "e2e:prod": "node scripts/e2e-prod.mjs",
    "serve": "node scripts/serve.mjs",
    "dev": "npm run build && npm run serve"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@vercel/blob": "^2.6.1"
  }
}
